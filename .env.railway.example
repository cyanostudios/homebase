# Copy these names into Railway → Variables (Homebase service only).
# Paste values from .env.local / Neon Console — never commit real secrets.

NODE_ENV=production
DATABASE_URL=postgresql://...@....neon.tech/neondb?sslmode=require
SESSION_SECRET=generate-with-openssl-rand-base64-32
TENANT_PROVIDER=neon
NEON_API_KEY=

APP_URL=https://your-homebase-service.up.railway.app
FRONTEND_URL=https://your-homebase-service.up.railway.app
ENABLE_CSRF=true

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Optional
CRON_SECRET=
PUBLIC_CUPS_URL=
PUBLIC_CUPS_USER_ID=
