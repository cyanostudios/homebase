# Cupappen Railway service (separate from Homebase API) — paste into Variables, never commit secrets.

# Tenant Postgres where the cups plugin stores rows (NOT Neon main / Homebase DATABASE_URL)
CUPS_DB_URL=postgresql://...@....neon.tech/neondb?sslmode=require

CUPS_ALLOWED_ORIGINS=https://cupappen.se,https://www.cupappen.se
CUPS_PUBLIC_SITE_URL=https://www.cupappen.se
CUPS_CACHE_TTL=60

# Temporary while debugging DB connection (shows error message in JSON)
# CUPS_DEBUG_ERRORS=1
