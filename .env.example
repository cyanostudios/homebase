# Homebase Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git!

# ============================================
# DATABASE CONFIGURATION
# ============================================

# PostgreSQL connection string
# Local development (Docker): postgresql://postgres:devpassword@localhost:5432/homebase_dev
# Neon (cloud): Get from Neon dashboard > Connection Details > Connection string
DATABASE_URL=postgresql://postgres:devpassword@localhost:5432/homebase_dev

# Tenant strategy: "local" = schema-per-tenant in same DB (required for local login when no tenants row exists)
# Set to "local" for local dev so login works after setup-database.js (creates tenant schema on first login)
# Omit or set to "neon" when using Neon tenant databases
TENANT_PROVIDER=local

# ============================================
# SERVER CONFIGURATION
# ============================================

# Environment mode: development | production
NODE_ENV=development

# Backend API server port (default: 3002)
# Frontend runs on 3001
PORT=3002

# Public static apps served on their own origins
# Used by CORS allowlist and public tenant pool routing
PUBLIC_BOOKING_URL=http://localhost:3003
PUBLIC_BOOKING_USER_ID=
PUBLIC_CUPS_URL=http://localhost:3004
PUBLIC_CUPS_USER_ID=

# Ingest plugin: enable headless browser fetch (browser_fetch) via Puppeteer/Chromium.
# Omit or leave unset = browser_fetch sources get a clear "not available" error from the API.
# Set to 1 only where Chromium OS deps are installed (see Puppeteer docs).
# INGEST_BROWSER_FETCH=1
#
# After enabling, install Chromium once from the repo root:
#   npm run puppeteer:install-chrome
# The API defaults PUPPETEER_CACHE_DIR to .cache/puppeteer (see server/index.ts) so installs are not tied to a sandbox TMP.
# If the environment injects a sandbox cache path (e.g. cursor-sandbox-cache), the server overrides it to the project .cache folder.
# Override if needed:
# PUPPETEER_CACHE_DIR=/absolute/path/to/.cache/puppeteer
#
# With INGEST_BROWSER_FETCH=1, the API logs one block at startup prefixed [ingest:browser_fetch]:
# env values, Chrome path + read/execute check, free/total memory MiB, HTTPS probe to example.com.

# Session secret for cookie encryption
# CRITICAL: Use a strong random string in production!
# Generate with: openssl rand -base64 32
SESSION_SECRET=homebase-dev-secret-change-in-production

# ============================================
# EXTERNAL API KEYS
# ============================================

# Trafikverket API Key (for Rail plugin)
# Get your key from: https://api.trafikinfo.trafikverket.se/
# Register account -> Create API key -> Copy here
TV_API_KEY=your_trafikverket_api_key_here

# ============================================
# DEPLOYMENT NOTES
# ============================================
#
# For production deployment:
# 1. Set DATABASE_URL to your Neon connection string
# 2. Change NODE_ENV to "production"
# 3. Generate strong SESSION_SECRET: openssl rand -base64 32
# 4. Add your TV_API_KEY from Trafikverket
# 5. Set these in your deployment platform (Vercel, Railway, etc.)
#
# For team members:
# 1. Copy this file to .env.local
# 2. Update DATABASE_URL with your database (local Docker or Neon)
# 3. Get TV_API_KEY from team lead or register your own
# 4. Never commit .env.local to git!
