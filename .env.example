# Homebase Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git!

# ============================================
# DATABASE CONFIGURATION
# ============================================

# PostgreSQL connection string
# Local development (Docker): postgresql://postgres:devpassword@localhost:5432/homebase_dev
# Neon (cloud): Get from Neon dashboard > Connection Details > Connection string
DATABASE_URL=postgresql://postgres:devpassword@localhost:5432/homebase_dev

# Tenant strategy: "local" = schema-per-tenant in same DB (required for local login when no tenants row exists)
# Set to "local" for local dev so login works after setup-database.js (creates tenant schema on first login)
# Omit or set to "neon" when using Neon tenant databases
TENANT_PROVIDER=local

# ============================================
# SERVER CONFIGURATION
# ============================================

# Environment mode: development | production
NODE_ENV=development

# Backend API server port (default: 3002)
# Frontend runs on 3001
PORT=3002

# Public static apps served on their own origins
# Used by CORS allowlist and public tenant pool routing
PUBLIC_BOOKING_URL=http://localhost:3003
PUBLIC_BOOKING_USER_ID=
PUBLIC_CUPS_URL=http://localhost:3004
PUBLIC_CUPS_USER_ID=

# Ingest plugin: enable headless browser fetch (browser_fetch) via Puppeteer/Chromium.
# Omit or leave unset = browser_fetch sources get a clear "not available" error from the API.
# Set to 1 only where Chromium OS deps are installed (see Puppeteer docs).
# INGEST_BROWSER_FETCH=1
#
# After enabling, install Chromium once from the repo root:
#   npm run puppeteer:install-chrome
# The API defaults PUPPETEER_CACHE_DIR to .cache/puppeteer (see server/index.ts) so installs are not tied to a sandbox TMP.
# If the environment injects a sandbox cache path (e.g. cursor-sandbox-cache), the server overrides it to the project .cache folder.
# Override if needed:
# PUPPETEER_CACHE_DIR=/absolute/path/to/.cache/puppeteer
#
# With INGEST_BROWSER_FETCH=1, the API logs one block at startup prefixed [ingest:browser_fetch]:
# env values, Chrome path + read/execute check, free/total memory MiB, HTTPS probe to example.com.

# Session secret for cookie encryption
# CRITICAL: Use a strong random string in production!
# Generate with: openssl rand -base64 32
SESSION_SECRET=homebase-dev-secret-change-in-production

# Cron secret: protects POST /api/cron/* endpoints (service-to-service, no user session).
# Set this in Railway Variables and in your local .env.local for manual test runs.
# Generate with: openssl rand -base64 32
# Used by Railway Cron: curl -X POST -H "x-cron-secret: $CRON_SECRET" https://$DOMAIN/api/cron/cups/refresh
CRON_SECRET=

# ============================================
# SECURITY (API + browser session)
# ============================================
#
# CSRF: When true, state-changing API calls require X-CSRF-Token (see /api/csrf-token).
# The SPA uses client/src/core/api/apiFetch.ts which attaches the token automatically.
# Leave unset/false in local dev; set ENABLE_CSRF=true in production and staging.
# Requires dependency: csurf (already in package.json).
# ENABLE_CSRF=true
#
# Rate limits: In non-production, global + auth limiters are skipped by default so Vite HMR
# and parallel plugin fetches do not hit 429. Set to test limits locally or in staging:
# FORCE_RATE_LIMIT=1
#
# CORS (production): Only FRONTEND_URL, PUBLIC_BOOKING_URL, PUBLIC_CUPS_URL (when set) are allowed.
# Set FRONTEND_URL to your real SPA origin before go-live.

# ============================================
# EXTERNAL API KEYS
# ============================================

# Trafikverket API Key (for Rail plugin)
# Get your key from: https://api.trafikinfo.trafikverket.se/
# Register account -> Create API key -> Copy here
TV_API_KEY=your_trafikverket_api_key_here

# ============================================
# CLOUD STORAGE (Files plugin – Google Drive)
# ============================================
#
# Google Drive integration lets the Files plugin store uploaded bytes in
# Google Drive instead of the local disk.  Leave empty to use local storage.
#
# Setup:
#   1. Create a project at https://console.cloud.google.com/
#   2. Enable the "Google Drive API"
#   3. OAuth 2.0 Credentials → Web application
#   4. Add authorized redirect URI:
#        {APP_URL}/api/files/cloud/googledrive/auth/callback
#   5. Copy Client ID and Secret below (or enter them in Files → Settings)
#
GOOGLEDRIVE_CLIENT_ID=
GOOGLEDRIVE_CLIENT_SECRET=

# Base URL of the backend API server (used as OAuth redirect base).
# Must match the authorized redirect URI registered in Google Cloud Console.
# Default: http://localhost:3000
APP_URL=http://localhost:3000

# Base URL of the frontend (used for post-OAuth redirect back to the app).
# Default: http://localhost:3001
FRONTEND_URL=http://localhost:3001

# ============================================
# DEPLOYMENT NOTES
# ============================================
#
# For production deployment:
# 1. Set DATABASE_URL to your Neon connection string
# 2. Change NODE_ENV to "production"
# 3. Generate strong SESSION_SECRET: openssl rand -base64 32
# 4. Set ENABLE_CSRF=true (CSRF protection for cookie sessions)
# 5. Set CRON_SECRET (openssl rand -base64 32) and configure Railway Cron (see docs/CUPS_AUTO_REFRESH_CRON.md)
# 6. Run main-DB migration for public share links: npm run migrate:public-share-routing
# 6. Add your TV_API_KEY from Trafikverket
# 7. Set APP_URL and FRONTEND_URL to your production domains
# 8. Set GOOGLEDRIVE_CLIENT_ID / GOOGLEDRIVE_CLIENT_SECRET if using Drive
# 9. Set these in your deployment platform (Vercel, Railway, etc.)
#
# Staging: Prefer NODE_ENV=production (or match prod) and FORCE_RATE_LIMIT=1 to validate 429 behaviour.
#
# For team members:
# 1. Copy this file to .env.local
# 2. Update DATABASE_URL with your database (local Docker or Neon)
# 3. Get TV_API_KEY from team lead or register your own
# 4. Never commit .env.local to git!
