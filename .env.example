# Homebase Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git!

# ============================================
# DATABASE CONFIGURATION
# ============================================

# PostgreSQL connection string
# Local development (Docker): postgresql://postgres:devpassword@localhost:5432/homebase_dev
# Neon (cloud): Get from Neon dashboard > Connection Details > Connection string
DATABASE_URL=postgresql://postgres:devpassword@localhost:5432/homebase_dev

# ============================================
# SERVER CONFIGURATION
# ============================================

# Environment mode: development | production
NODE_ENV=development

# Backend API server port (default: 3002)
# Frontend runs on 3001
PORT=3002

# Session secret for cookie encryption
# CRITICAL: Use a strong random string in production!
# Generate with: openssl rand -base64 32
SESSION_SECRET=homebase-dev-secret-change-in-production

# Credentials encryption key (used for encrypting stored API keys/passwords)
# CRITICAL: required in production, 32+ random bytes recommended
# Generate with: openssl rand -base64 32
CREDENTIALS_ENCRYPTION_KEY=replace_with_strong_random_key

# MFA (two-factor authentication): set to "true" in production; omit or "false" in dev to skip TOTP
# MFA_ENABLED=true

# ============================================
# EXTERNAL API KEYS
# ============================================

# Trafikverket API Key (for Rail plugin)
# Get your key from: https://api.trafikinfo.trafikverket.se/
# Register account -> Create API key -> Copy here
TV_API_KEY=your_trafikverket_api_key_here

# ============================================
# CF7 WEBHOOK INTAKE (Besiktningsförfrågningar)
# ============================================

# Shared secret between CF7 to Webhook and Homebase (same as hidden webhook_secret in form)
CF7_WEBHOOK_SECRET=din_hemliga_nyckel_ändra_i_produktion

# User ID that will own intake projects (must exist and have inspection/files access)
CF7_INTAKE_USER_ID=1

# For protected WordPress uploads: token for fetching files on 401/403
# WP_BASE_URL=https://din-wordpress.se
# WP_WEBHOOK_TOKEN=din_wp_token
# WP_FILE_FETCH_ENDPOINT=/wp-json/homebase-intake/v1/file

# ============================================
# DEPLOYMENT NOTES
# ============================================
#
# For production deployment:
# 1. Set DATABASE_URL to your Neon connection string
# 2. Change NODE_ENV to "production"
# 3. Generate strong SESSION_SECRET: openssl rand -base64 32
# 4. Add your TV_API_KEY from Trafikverket
# 5. Set CREDENTIALS_ENCRYPTION_KEY
# 6. Set these in your deployment platform (Vercel, Railway, etc.)
#
# For team members:
# 1. Copy this file to .env.local
# 2. Update DATABASE_URL with your database (local Docker or Neon)
# 3. Get TV_API_KEY from team lead or register your own
# 4. Never commit .env.local to git!
